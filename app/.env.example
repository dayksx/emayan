# XRPL Network Configuration
NEXT_PUBLIC_DEFAULT_NETWORK=alphanet

# Optional: Custom network endpoints
# NEXT_PUBLIC_ALPHANET_WSS=wss://alphanet.nerdnest.xyz
# NEXT_PUBLIC_ALPHANET_FAUCET=https://alphanet.faucet.nerdnest.xyz/accounts

# Optional: Telegram bot for grievance notifications (server-only; do not expose as NEXT_PUBLIC_)
# Create a bot with @BotFather. For DMs the recipient must /start your bot first.
TELEGRAM_BOT_TOKEN=
# Optional: your numeric chat id (from @userinfobot) — server sends a copy of every grievance here too.
# TELEGRAM_NOTIFY_CHAT_ID=834948758
